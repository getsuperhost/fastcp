# FastCP Environment Configuration
# Copy this file to .env and update the values as needed

# Django Configuration
IS_DEBUG=1
DJANGO_SETTINGS_MODULE=fastcp.settings
SECRET_KEY=your-secret-key-here

# Database Configuration (SQLite by default)
# DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/fastcp
# For MySQL: DATABASE_URL=mysql://user:password@localhost:3306/fastcp

# Server Configuration
ALLOWED_HOSTS=localhost,127.0.0.1
PORT=8899

# Security Settings
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0

# Email Configuration (optional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# External Services (for update.py)
# B2_APP_KEY_ID=your-backblaze-key-id
# B2_APP_KEY=your-backblaze-app-key

# Development Settings
LOG_LEVEL=INFO
ENABLE_DEBUG_TOOLBAR=0
